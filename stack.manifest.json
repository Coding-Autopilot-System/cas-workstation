{
  "manifestVersion": "1.0.0",
  "bundleName": "CAS Workstation",
  "bundleId": "cas-workstation",
  "defaults": {
    "rootPath": "C:\\CodingAutopilotSystem",
    "configPath": "C:\\Users\\KimHarjamaki\\.cas",
    "profile": "full"
  },
  "policy": {
    "allowedInstallerKinds": ["winget", "scoop", "npm", "manual"],
    "allowedCommands": ["git", "gh", "node", "npm", "python", "uv", "dotnet", "docker", "az", "wsl.exe", "codex", "claude", "gemini"],
    "allowedRepositoryPrefixes": ["https://github.com/Coding-Autopilot-System/"],
    "allowedConfigTargets": ["codex.mcp.json", "claude.settings.fragment.json", "gemini.mcp.json"],
    "allowedAdapters": ["json-mcp", "tree-copy"]
  },
  "profiles": {
    "core": {
      "description": "Base workstation for AI-native coding.",
      "tools": { "required": ["git", "gh", "node", "npm", "python", "uv", "dotnet", "docker", "az", "wsl", "codex", "claude", "gemini"], "optional": [] },
      "repos": { "required": ["Promptimprover", "autogen", "gsd-orchestrator"], "optional": [] },
      "services": { "required": ["docker-daemon", "gh-auth"], "optional": [] },
      "clients": { "required": ["codex", "claude", "gemini"], "optional": [] },
      "skills": { "required": [], "optional": ["prompt-refiner"] },
      "workspaces": { "required": [], "optional": ["cas-default"] }
    },
    "full": {
      "description": "Full workstation with org automation components.",
      "tools": { "required": ["git", "gh", "node", "npm", "python", "uv", "dotnet", "docker", "az", "wsl", "codex", "claude", "gemini"], "optional": [] },
      "repos": { "required": ["Promptimprover", "autogen", "gsd-orchestrator", "autopilot-core", "ci-autopilot", "cas-platform", "cas-contracts", "cas-evals", "cas-reference-product"], "optional": [] },
      "services": { "required": ["docker-daemon", "gh-auth"], "optional": [] },
      "clients": { "required": ["codex", "claude", "gemini"], "optional": [] },
      "skills": { "required": ["prompt-refiner"], "optional": [] },
      "workspaces": { "required": ["cas-default"], "optional": [] }
    }
  },
  "paths": {
    "reposRoot": "repos",
    "logs": "logs",
    "state": "state",
    "memory": "memory",
    "mcp": "mcp",
    "config": "config"
  },
  "tools": [
    {
      "id": "git",
      "displayName": "Git",
      "command": "git",
      "versionArgs": [
        "--version"
      ],
      "versionPattern": "(?<version>\\d+\\.\\d+\\.\\d+)",
      "minimumVersion": "2.53.0",
      "installers": [
        {
          "kind": "winget",
          "id": "Git.Git"
        },
        {
          "kind": "scoop",
          "id": "git"
        }
      ]
    },
    {
      "id": "gh",
      "displayName": "GitHub CLI",
      "command": "gh",
      "versionArgs": [
        "--version"
      ],
      "versionPattern": "(?<version>\\d+\\.\\d+\\.\\d+)",
      "minimumVersion": "2.86.0",
      "installers": [
        {
          "kind": "winget",
          "id": "GitHub.cli"
        },
        {
          "kind": "scoop",
          "id": "gh"
        }
      ]
    },
    {
      "id": "node",
      "displayName": "Node.js",
      "command": "node",
      "versionArgs": [
        "--version"
      ],
      "versionPattern": "(?<version>\\d+\\.\\d+\\.\\d+)",
      "minimumVersion": "22.0.0",
      "installers": [
        {
          "kind": "winget",
          "id": "OpenJS.NodeJS"
        },
        {
          "kind": "scoop",
          "id": "nodejs"
        }
      ]
    },
    {
      "id": "npm",
      "displayName": "npm",
      "command": "npm",
      "versionArgs": [
        "--version"
      ],
      "versionPattern": "(?<version>\\d+\\.\\d+\\.\\d+)",
      "minimumVersion": "11.0.0",
      "installers": []
    },
    {
      "id": "python",
      "displayName": "Python",
      "command": "python",
      "versionArgs": [
        "--version"
      ],
      "versionPattern": "(?<version>\\d+\\.\\d+\\.\\d+)",
      "minimumVersion": "3.12.0",
      "installers": [
        {
          "kind": "winget",
          "id": "Python.Python.3.12"
        },
        {
          "kind": "scoop",
          "id": "python"
        }
      ]
    },
    {
      "id": "uv",
      "displayName": "uv",
      "command": "uv",
      "versionArgs": [
        "--version"
      ],
      "versionPattern": "(?<version>\\d+\\.\\d+\\.\\d+)",
      "minimumVersion": "0.4.0",
      "installers": [
        {
          "kind": "winget",
          "id": "Astral-sh.uv"
        },
        {
          "kind": "scoop",
          "id": "uv"
        }
      ]
    },
    {
      "id": "dotnet",
      "displayName": ".NET SDK",
      "command": "dotnet",
      "versionArgs": [
        "--version"
      ],
      "versionPattern": "(?<version>\\d+\\.\\d+\\.\\d+)",
      "minimumVersion": "10.0.0",
      "installers": [
        {
          "kind": "winget",
          "id": "Microsoft.DotNet.SDK.10"
        },
        {
          "kind": "scoop",
          "id": "dotnet-sdk"
        }
      ]
    },
    {
      "id": "docker",
      "displayName": "Docker Desktop",
      "command": "docker",
      "versionArgs": [
        "--version"
      ],
      "versionPattern": "(?<version>\\d+\\.\\d+\\.\\d+)",
      "minimumVersion": "29.0.0",
      "installers": [
        {
          "kind": "winget",
          "id": "Docker.DockerDesktop"
        }
      ]
    },
    {
      "id": "az",
      "displayName": "Azure CLI",
      "command": "az",
      "versionArgs": [
        "--version"
      ],
      "versionPattern": "(?<version>\\d+\\.\\d+\\.\\d+)",
      "minimumVersion": "2.80.0",
      "installers": [
        {
          "kind": "winget",
          "id": "Microsoft.AzureCLI"
        },
        {
          "kind": "scoop",
          "id": "azure-cli"
        }
      ]
    },
    {
      "id": "wsl",
      "displayName": "WSL",
      "command": "wsl.exe",
      "versionArgs": [
        "--status"
      ],
      "versionPattern": "(?<version>\\d+)",
      "minimumVersion": "2.0.0",
      "installers": [
        {
          "kind": "manual",
          "hint": "Enable WSL with: wsl --install"
        }
      ]
    },
    {
      "id": "codex",
      "displayName": "Codex CLI",
      "command": "codex",
      "versionArgs": [
        "--version"
      ],
      "versionPattern": "(?<version>\\d+\\.\\d+\\.\\d+)",
      "minimumVersion": "0.125.0",
      "installers": [
        {
          "kind": "npm",
          "id": "@openai/codex"
        }
      ]
    },
    {
      "id": "claude",
      "displayName": "Claude Code",
      "command": "claude",
      "versionArgs": [
        "--version"
      ],
      "versionPattern": "(?<version>\\d+\\.\\d+\\.\\d+)",
      "minimumVersion": "2.0.0",
      "installers": [
        {
          "kind": "npm",
          "id": "@anthropic-ai/claude-code"
        }
      ]
    },
    {
      "id": "gemini",
      "displayName": "Gemini CLI",
      "command": "gemini",
      "versionArgs": [
        "--version"
      ],
      "versionPattern": "(?<version>\\d+\\.\\d+\\.\\d+)",
      "minimumVersion": "0.45.0",
      "installers": [
        {
          "kind": "npm",
          "id": "@google/gemini-cli"
        }
      ]
    }
  ],
  "repos": [
    {
      "id": "Promptimprover",
      "url": "https://github.com/Coding-Autopilot-System/Promptimprover.git",
      "defaultBranch": "master"
    },
    {
      "id": "autogen",
      "url": "https://github.com/Coding-Autopilot-System/autogen.git",
      "defaultBranch": "main"
    },
    {
      "id": "gsd-orchestrator",
      "url": "https://github.com/Coding-Autopilot-System/gsd-orchestrator.git",
      "defaultBranch": "main"
    },
    {
      "id": "autopilot-core",
      "url": "https://github.com/Coding-Autopilot-System/autopilot-core.git",
      "defaultBranch": "main"
    },
    {
      "id": "ci-autopilot",
      "url": "https://github.com/Coding-Autopilot-System/ci-autopilot.git",
      "defaultBranch": "main"
    },
    {
      "id": "cas-platform",
      "url": "https://github.com/Coding-Autopilot-System/cas-platform.git",
      "defaultBranch": "main"
    },
    {
      "id": "cas-contracts",
      "url": "https://github.com/Coding-Autopilot-System/cas-contracts.git",
      "defaultBranch": "main"
    },
    {
      "id": "cas-evals",
      "url": "https://github.com/Coding-Autopilot-System/cas-evals.git",
      "defaultBranch": "main"
    },
    {
      "id": "cas-reference-product",
      "url": "https://github.com/Coding-Autopilot-System/cas-reference-product.git",
      "defaultBranch": "main"
    }
  ],
  "services": [
    { "id": "docker-daemon" },
    { "id": "gh-auth" }
  ],
  "clients": [
    {
      "id": "codex",
      "fileName": "codex.mcp.json",
      "adapter": "json-mcp",
      "ownershipKey": "cas-workstation.prompt-refiner"
    },
    {
      "id": "claude",
      "fileName": "claude.settings.fragment.json",
      "adapter": "json-mcp",
      "ownershipKey": "cas-workstation.prompt-refiner"
    },
    {
      "id": "gemini",
      "fileName": "gemini.mcp.json",
      "adapter": "json-mcp",
      "ownershipKey": "cas-workstation.prompt-refiner"
    }
  ],
  "skills": [
    {
      "id": "prompt-refiner",
      "repo": "Promptimprover",
      "sourceRelativePath": "skills\\prompt-refiner",
      "targetRelativePath": "skills\\prompt-refiner",
      "adapter": "tree-copy"
    }
  ],
  "workspaces": [
    {
      "id": "cas-default",
      "repo": "cas-reference-product",
      "sourceRelativePath": "docs",
      "targetRelativePath": "workspaces\\default",
      "adapter": "tree-copy"
    }
  ],
  "sharedMcpServer": {
    "name": "prompt-refiner",
    "transport": "stdio",
    "scope": "local-workstation",
    "authReference": null,
    "command": "node",
    "args": [
      "C:\\CodingAutopilotSystem\\repos\\Promptimprover\\dist\\index.js"
    ]
  }
}
